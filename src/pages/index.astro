---
import Faq from "@/components/Faq.astro";
import FinalCta from "@/components/FinalCta.astro";
import Hero from "@/components/Hero.astro";
import ItaunasSection from "@/components/ItaunasSection.astro";
import Lineup from "@/components/Lineup.astro";
import PlanTrip from "@/components/PlanTrip.astro";
import QuickAnswer from "@/components/QuickAnswer.astro";
import SeoHead from "@/components/SeoHead.astro";
import TfdSection from "@/components/TfdSection.astro";
import VenueStory from "@/components/VenueStory.astro";
import "@/styles/global.css";
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <SeoHead />
  </head>
  <body>
    <main class="page-shell">
      <Hero />
      <QuickAnswer />
      <Lineup />
      <TfdSection />
      <PlanTrip />
      <VenueStory />
      <ItaunasSection />
      <Faq />
      <FinalCta />
    </main>
  </body>
</html>
