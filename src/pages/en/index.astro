---
import Faq from "@/components/Faq.astro";
import FinalCta from "@/components/FinalCta.astro";
import Hero from "@/components/Hero.astro";
import ItaunasSection from "@/components/ItaunasSection.astro";
import Lineup from "@/components/Lineup.astro";
import PlanTrip from "@/components/PlanTrip.astro";
import QuickAnswer from "@/components/QuickAnswer.astro";
import SeoHead from "@/components/SeoHead.astro";
import TfdSection from "@/components/TfdSection.astro";
import VenueStory from "@/components/VenueStory.astro";
import { festivalPages } from "@/data/festival";
import "@/styles/global.css";

const content = festivalPages.en;
---

<!doctype html>
<html lang={content.locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <SeoHead content={content} />
  </head>
  <body>
    <main class="page-shell">
      <Hero content={content} />
      <Lineup content={content} />
      <QuickAnswer content={content} />
      <TfdSection content={content} />
      <PlanTrip content={content} />
      <VenueStory content={content} />
      <ItaunasSection content={content} />
      <Faq content={content} />
      <FinalCta content={content} />
    </main>
  </body>
</html>
