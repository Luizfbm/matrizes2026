---
import type { FestivalPage } from "@/data/festival";

interface Props {
  content: FestivalPage;
}

const { content } = Astro.props;
---

<section class="section" aria-labelledby="itaunas-title">
  <div class="section-inner">
    <p class="eyebrow">{content.sections.itaunasEyebrow}</p>
    <h2 id="itaunas-title" class="section-title">{content.sections.itaunasTitle}</h2>
    <p>{content.sections.itaunasText}</p>
  </div>
</section>
