---
import type { FestivalPage } from "@/data/festival";

interface Props {
  content: FestivalPage;
}

const { content } = Astro.props;
---

<section class="section section--green" aria-labelledby="tfd-title">
  <div class="section-inner">
    <div class="tfd-layout">
      <div class="tfd-content">
        <p class="eyebrow">TFD</p>
        <h2 id="tfd-title" class="section-title">{content.sections.tfdTitle}</h2>
        <p>{content.sections.tfdText}</p>
        <div class="tfd-actions" aria-label={content.sections.tfdLinksLabel}>
          {
            content.sections.tfdLinks.map((link, index) => (
              <a class={index === 0 ? "button" : "button secondary"} href={link.href} target="_blank" rel="noopener noreferrer">
                {link.label}
              </a>
            ))
          }
        </div>
      </div>
      <figure class="festival-photo festival-photo--dance">
      <img
        src={content.images.danceSrc}
        alt={content.images.danceAlt}
        loading="lazy"
        decoding="async"
      />
      </figure>
    </div>
  </div>
</section>
