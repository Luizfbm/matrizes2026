---
import type { FestivalPage } from "@/data/festival";

interface Props {
  content: FestivalPage;
}

const { content } = Astro.props;
---

<section class="section section--red" aria-labelledby="venue-title">
  <div class="section-inner">
    <p class="eyebrow">{content.sections.venueEyebrow}</p>
    <h2 id="venue-title" class="section-title">{content.sections.venueTitle}</h2>
    <p>{content.sections.venueText}</p>
    <figure class="festival-photo festival-photo--venue">
      <img
        src={content.images.venueSrc}
        alt={content.images.venueAlt}
        loading="lazy"
        decoding="async"
      />
    </figure>
  </div>
</section>
