---
import type { FestivalPage } from "@/data/festival";

interface Props {
  content: FestivalPage;
}

const { content } = Astro.props;
---

<section class="section final-cta" aria-labelledby="cta-title">
  <div class="section-inner">
    <p class="eyebrow">{content.displayDate}</p>
    <h2 id="cta-title" class="section-title">{content.sections.finalTitle}</h2>
    <p>{content.sections.finalText}</p>
    <a class="button" href={content.links.tickets}>{content.sections.finalCta}</a>
  </div>
</section>
