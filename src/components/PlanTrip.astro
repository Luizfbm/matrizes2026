---
import { festival } from "@/data/festival";
---

<section class="section" aria-labelledby="trip-title">
  <div class="section-inner">
    <p class="eyebrow">Planeje sua ida</p>
    <h2 id="trip-title" class="section-title">Ingressos, hospedagem e Itaúnas</h2>
    <div class="info-grid">
      <article><h3>Ingressos</h3><p>Compre pelos canais oficiais do Buraco do Tatu.</p></article>
      <article><h3>Hospedagem</h3><p>Use os destaques e links oficiais para encontrar opções na vila e arredores.</p></article>
      <article><h3>Excursão</h3><p>Confira informações oficiais sobre excursão, chegada e deslocamento.</p></article>
      <article><h3>Local</h3><p>{festival.venue.name}, Itaúnas, Conceição da Barra - ES.</p></article>
    </div>
  </div>
</section>
