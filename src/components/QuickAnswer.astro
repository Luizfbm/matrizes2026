---
import type { FestivalPage } from "@/data/festival";

interface Props {
  content: FestivalPage;
}

const { content } = Astro.props;
---

<section class="section answer-block" aria-labelledby="resumo">
  <div class="section-inner">
    <p class="eyebrow">{content.sections.quickEyebrow}</p>
    <h2 id="resumo" class="section-title">{content.sections.quickTitle}</h2>
    <p class="answer-block__text">{content.quickAnswer}</p>
    <p>{content.searchAnswer}</p>
  </div>
</section>
