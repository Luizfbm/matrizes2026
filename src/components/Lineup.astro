---
import type { FestivalPage } from "@/data/festival";

interface Props {
  content: FestivalPage;
}

const { content } = Astro.props;
---

<section id="programacao" class="section" aria-labelledby="programacao-title">
  <div class="section-inner">
    <p class="eyebrow">{content.sections.lineupEyebrow}</p>
    <h2 id="programacao-title" class="section-title">{content.sections.lineupTitle}</h2>
    <p>{content.sections.programNote}</p>
    <figure class="festival-photo festival-photo--lineup">
      <img
        src={content.images.lineupSrc}
        alt={content.images.lineupAlt}
        loading="lazy"
        decoding="async"
      />
    </figure>
    <ul class="lineup-grid">
      {content.lineup.map((artist) => <li>{artist}</li>)}
    </ul>
    <div class="lineup-subsection">
      <h3>{content.sections.vinylLineupTitle}</h3>
      <ul class="lineup-grid lineup-grid--secondary">
        {content.vinylLineup.map((artist) => <li>{artist}</li>)}
      </ul>
    </div>
    <a class="button" href={content.links.tickets}>{content.sections.ticketCta}</a>
  </div>
</section>
