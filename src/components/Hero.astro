---
import type { FestivalPage } from "@/data/festival";

interface Props {
  content: FestivalPage;
}

const { content } = Astro.props;
---

<section class="hero">
  <div class="poster-band" aria-hidden="true"></div>
  <div class="hero__inner">
    <div class="hero__content">
      <a class="language-switch" href={content.alternatePath}>{content.alternateLabel}</a>
      <p class="eyebrow">{content.hero.eyebrow}</p>
      <h1>{content.hero.title}</h1>
      <p class="hero__lead">{content.hero.lead}</p>
      <div class="hero__actions">
        <a class="button" href="#programacao">{content.hero.primaryCta}</a>
        <a class="button secondary" href={content.links.tickets}>{content.hero.secondaryCta}</a>
      </div>
    </div>
    <figure class="festival-photo festival-photo--hero">
      <img
        src={content.images.heroSrc}
        alt={content.images.heroAlt}
        loading="eager"
        decoding="async"
      />
    </figure>
    <dl class="hero__facts">
      {content.hero.facts.map((fact) => <div><dt>{fact.label}</dt><dd>{fact.value}</dd></div>)}
    </dl>
  </div>
</section>
